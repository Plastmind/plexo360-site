# Cloudflare Pages — controle de cache
# O HTML e o service-worker nunca ficam presos em cache do CDN,
# garantindo que atualizações cheguem aos usuários no próximo acesso.
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/service-worker.js
  Cache-Control: public, max-age=0, must-revalidate
